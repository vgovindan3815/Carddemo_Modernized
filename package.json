{
  "name": "carddemo-modernized",
  "version": "1.0.0",
  "description": "AWS CardDemo - Mainframe Modernization (CICS/COBOL to Angular/Node.js)",
  "keywords": [
    "mainframe",
    "modernization",
    "cobol",
    "cics",
    "angular",
    "node.js"
  ],
  "homepage": "https://github.com/vgovindan3815/Carddemo_Modernized",
  "repository": {
    "type": "git",
    "url": "https://github.com/vgovindan3815/Carddemo_Modernized.git"
  },
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "build:frontend": "cd frontend && npm run build -- --configuration production",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:ps": "docker-compose ps",
    "docker:deploy": "powershell .\\deploy\\deploy-docker.ps1",
    "test": "cd backend && npm test",
    "clean": "docker-compose down -v"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "author": {
    "name": "Accenture"
  },
  "license": "ISC"
}
